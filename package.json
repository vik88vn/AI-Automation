{
  "name": "ai-qa-engineer",
  "version": "1.0.0",
  "description": "Autonomous AI QA Engineer - explores live web apps, generates test plans with Claude, and executes them via Playwright",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc && mkdir -p dist/agent && cp src/agent/dashboard.html dist/agent/dashboard.html",
    "typecheck": "tsc --noEmit",
    "qa": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "node scripts/serve.mjs",
    "demo": "node scripts/seed-demo.mjs",
    "install-browsers": "playwright install chromium",
    "agent": "tsx src/agent/cli.ts",
    "agent:serve": "tsx src/agent/serve.ts"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "playwright": "^1.48.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
