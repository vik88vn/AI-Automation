# ============================================================================
# AI QA Engineer Environment Variables
# ============================================================================
# Copy this to .env and fill in your values

# ============================================================================
# Server Configuration
# ============================================================================
AGENT_PORT=4310                          # Backend HTTP server port (default 4310)
NODE_ENV=development                     # development | production

# ============================================================================
# LLM Provider (choose one: Anthropic, OpenAI, or Ollama)
# ============================================================================

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...            # Get from https://console.anthropic.com

# OpenAI GPT
OPENAI_API_KEY=sk-...                   # Get from https://platform.openai.com/api-keys

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434  # Default: local Ollama server
OLLAMA_MODEL=llama3.2                   # Default model to use

# ============================================================================
# Database (PostgreSQL) - for multi-tenancy
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/ai_qa_engineer

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=your-secret-key-change-me    # Generate with: openssl rand -hex 32

# ============================================================================
# File Storage (Cloudflare R2 or AWS S3) - for SaaS deployment
# ============================================================================

# Cloudflare R2
R2_BUCKET_NAME=ai-qa-reports
R2_ACCOUNT_ID=your-cloudflare-account
R2_ACCESS_KEY_ID=your-r2-api-key
R2_SECRET_ACCESS_KEY=your-r2-secret

# ============================================================================
# CORS Configuration (for SaaS deployment)
# ============================================================================
CORS_ORIGIN=http://localhost:5173       # Local dev: frontend origin
                                        # Production: https://example.com

# ============================================================================
# QA Agent Configuration
# ============================================================================
QA_TARGET_URL=https://example.com       # Default target URL for testing
QA_HEADLESS=true                        # Run browser headless (always true in prod)
QA_MAX_STEPS=40                         # Maximum agent iterations
QA_TEST_TIMEOUT_MS=30000                # Test timeout in milliseconds
QA_REPORT_DIR=./reports                 # Local dir (before uploading to R2)

# ============================================================================
# Fix Agent Configuration (Phase 4)
# ============================================================================
PROJECT_ROOT=/Users/me/my-project       # Where user projects are uploaded/cloned
ENABLE_FIX_AGENT=true                   # Enable the bug fix agent

# GitHub Integration (for fix agent)
GITHUB_TOKEN=ghp_...                    # Optional: for cloning/pushing fixes

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_CHAT=true                        # Enable post-run chat panel
ENABLE_MULTI_TENANT=false               # Enable multi-tenancy (Phase 3)
